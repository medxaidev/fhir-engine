{
  "name": "fhir-engine",
  "version": "0.4.1",
  "description": "FHIR Engine for healthcare data management",
  "homepage": "https://github.com/medxaidev/fhir-engine#readme",
  "license": "MIT",
  "author": "Fangjun <fangjun20208@gmail.com>",
  "keywords": [
    "fhir",
    "fhir-r4",
    "fhir-persistence",
    "fhir-server",
    "fhir-search",
    "hl7",
    "healthcare",
    "sqlite",
    "postgresql",
    "embedded-database",
    "schema-migration",
    "search-indexing",
    "typescript",
    "interoperability",
    "clinical",
    "ehr"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/medxaidev/fhir-engine.git"
  },
  "bugs": {
    "url": "https://github.com/medxaidev/fhir-engine/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.mjs"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/esm",
    "dist/cjs",
    "dist/index.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc && node ./scripts/esbuild.mjs",
    "test": "vitest run",
    "prepublishOnly": "npm run test && npm run build"
  },
  "dependencies": {
    "fhir-definition": "^0.5.0",
    "fhir-runtime": "^0.8.1",
    "fhir-persistence": "^0.1.0"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.57.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.2.0",
    "esbuild": "0.27.2",
    "rimraf": "6.1.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
